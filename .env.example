# Outlays — example environment. Copy to .env and fill in. NEVER commit .env.

# --- Postgres (system of record) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=fiscal
POSTGRES_USER=fiscal_app
POSTGRES_PASSWORD=change_me
# Superuser/owner role used only for migrations (goose), not by the app at runtime.
POSTGRES_OWNER_USER=fiscal_owner
POSTGRES_OWNER_PASSWORD=change_me_too
# App runtime role; app connects as this (app_rw) and must NOT hold UPDATE/DELETE.
DATABASE_URL=postgres://fiscal_app:change_me@localhost:5433/fiscal?sslmode=disable
MIGRATE_DATABASE_URL=postgres://fiscal_owner:change_me_too@localhost:5433/fiscal?sslmode=disable

# --- Object storage (S3 API; MinIO locally) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=fiscal-raw
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Upstream etiquette ---
# User-Agent: outlays/<version> (+repo URL). Set the contact repo URL here.
OUTLAYS_USER_AGENT_CONTACT=https://github.com/djmagro/outlays
OUTLAYS_RATE_LIMIT_PER_HOST_RPS=1

# --- Anchor layer (S12; local anvil) ---
ANCHOR_RPC_URL=http://localhost:8545
# Anvil dev key — local only, never a real key.
ANCHOR_PRIVATE_KEY=
ANCHOR_REGISTRY_ADDRESS=
