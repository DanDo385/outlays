    "test": "tsx test/validate.test.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
